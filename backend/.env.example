GREENIFY_ENV=development
HOST=0.0.0.0
PORT=8000
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_MAX_TOKENS=1500
ANTHROPIC_TEMPERATURE=0
REAL_SMART_PLUG_ENABLED=false
REAL_SMART_PLUG_API_KEY=

# Apple Shortcuts adapter (macOS demo; highest priority when both sets exist).
# Plug is commissioned in Apple Home; Shortcuts app has two shortcuts that
# each call "Home: Set <accessory> -> Power On/Off". One pair per device:
#   APPLE_SHORTCUT_<DEVICE_ID>_ON / _OFF
APPLE_SHORTCUT_OFFICE_DEMO_PLUG_LAMP_ON=Greenify Plug On
APPLE_SHORTCUT_OFFICE_DEMO_PLUG_LAMP_OFF=Greenify Plug Off

# Home Assistant + Matter adapter (Linux-only in practice — Docker Desktop on
# macOS cannot give the matter-server container real LAN/mDNS access, and the
# CHIP SDK has no Apple Silicon wheels). Kept for non-Mac deployments.
HA_BASE_URL=http://localhost:8123
HA_TOKEN=
HA_ENTITY_ID_OFFICE_DEMO_PLUG_LAMP=switch.office_demo_plug_lamp
